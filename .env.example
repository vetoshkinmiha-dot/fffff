# Database
DATABASE_URL="postgresql://user:password@localhost:5432/contractor_demo"

# JWT Secret (generate a strong random string for production)
JWT_SECRET="your-jwt-secret-here"

# CRON Secret for /api/cron/* endpoints (generate a strong random string)
CRON_SECRET="your-cron-secret-here"

# SMTP (email notifications — leave blank in dev, emails go to console)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@company.ru"

# Application URL (used in email links)
APP_URL="http://localhost:3000"

# S3 Storage
S3_BUCKET=contractor-demo
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
# S3_ENDPOINT= (optional, for S3-compatible services like MinIO)
# S3_PUBLIC_URL= (optional, for custom CDN prefix)

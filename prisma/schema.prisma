generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── Enums ─────────────────────────────────────────────────────

enum UserRole {
  admin
  factory_hse
  factory_hr
  factory_curator
  contractor_admin
  contractor_user
  security
  permit_bureau
}

enum ApprovalDepartment {
  security
  hr
  safety
  safety_training
  permit_bureau
}

enum OrgStatus {
  pending
  active
  blocked
}

enum DocStatus {
  valid
  expiring
  expired
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

// ─── Users & Auth ──────────────────────────────────────────────

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String    @map("password_hash")
  fullName       String    @map("full_name")
  role           UserRole
  organizationId String?   @map("organization_id")
  department     ApprovalDepartment?
  isActive       Boolean   @default(true) @map("is_active")
  mustChangePwd  Boolean   @default(true) @map("must_change_pwd")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdViolations       Violation[]       @relation("ViolationCreator")
  createdTemplates        ViolationTemplate[] @relation("TemplateCreator")
  createdChecklists       Checklist[]       @relation("ChecklistCreator")
  createdRegDocuments     RegDocument[]     @relation("RegDocCreator")
  notificationSubscriptions NotificationSubscription[] @relation("NotificationSubscriber")

  @@map("user")
}

// ─── Organizations ─────────────────────────────────────────────

model Organization {
  id                String     @id @default(uuid())
  sequentialNumber  Int        @unique @default(0) @map("sequential_number")
  name              String
  inn               String     @unique
  kpp               String?
  legalAddress      String     @map("legal_address")
  contactPersonName String?    @map("contact_person_name")
  contactPhone      String?    @map("contact_phone")
  contactEmail      String?    @map("contact_email")
  status            OrgStatus  @default(pending)
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  employees         Employee[]
  users             User[]
  permits           Permit[]
  violations        Violation[]
  checklists        Checklist[]

  @@map("organization")
}

// ─── Employees ─────────────────────────────────────────────────

model Employee {
  id                  String    @id @default(uuid())
  organizationId      String    @map("organization_id")
  fullName            String    @map("full_name")
  position            String
  photoUrl            String?   @map("photo_url")
  passportSeries      String    @map("passport_series")
  passportNumber      String    @map("passport_number")
  passportIssuedBy    String?   @map("passport_issued_by")
  passportIssueDate   DateTime? @map("passport_issue_date")
  previouslyAtPirelli Boolean   @default(false) @map("previously_at_pirelli")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workClasses         EmployeeWorkClass[]
  documents           EmployeeDocument[]
  approvals           ApprovalRequest[]

  @@unique([organizationId, passportSeries, passportNumber])
  @@map("employee")
}

// ─── Employee Work Classes (relation table for SQLite compat) ──

model EmployeeWorkClass {
  id           String       @id @default(uuid())
  employeeId   String       @map("employee_id")
  workClass    String       @map("work_class")
  createdAt    DateTime     @default(now()) @map("created_at")

  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, workClass])
  @@map("employee_work_class")
}

// ─── Employee Documents ────────────────────────────────────────

model EmployeeDocument {
  id         String    @id @default(uuid())
  employeeId String    @map("employee_id")
  name       String
  fileUrl    String?   @map("file_url")
  issueDate  DateTime? @map("issue_date")
  expiryDate DateTime? @map("expiry_date")
  status     DocStatus @default(valid)
  createdAt  DateTime  @default(now()) @map("created_at")

  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("employee_document")
}

// ─── Approval Requests ─────────────────────────────────────────

model ApprovalRequest {
  id         String           @id @default(uuid())
  employeeId String           @map("employee_id")
  department ApprovalDepartment
  status     ApprovalStatus   @default(pending)
  deadline   DateTime
  comment    String?
  decidedAt  DateTime?        @map("decided_at")
  createdAt  DateTime         @default(now()) @map("created_at")

  employee   Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("approval_request")
}

enum EmailLogStatus {
  SENT
  FAILED
  PENDING
}

model EmailLog {
  id        String        @id @default(uuid())
  recipient String
  subject   String
  template  String
  status    EmailLogStatus @default(PENDING)
  sentAt    DateTime?     @map("sent_at")
  error     String?
  createdAt DateTime      @default(now()) @map("created_at")

  @@map("email_log")
}

// ─── Permits (Наряды-допуски) ───────────────────────────────────

enum PermitWorkCategory {
  hot_work
  height_work
  confined_space
  electrical
  excavation
  other
}

enum PermitStatus {
  draft
  pending_approval
  approved
  active
  early_closed
  closed
  expired
}

model Permit {
  id                 String            @id @default(uuid())
  permitNumber       String            @unique @map("permit_number")
  category           PermitWorkCategory
  contractorId       String            @map("contractor_id")
  workSite           String            @map("work_site")
  responsiblePerson  String            @map("responsible_person")
  openDate           DateTime          @map("open_date")
  expiryDate         DateTime          @map("expiry_date")
  status             PermitStatus      @default(draft)
  closeReason        String?           @map("close_reason")
  closedAt           DateTime?         @map("closed_at")
  sequentialNumber   Int               @default(0) @map("sequential_number")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  contractor         Organization      @relation(fields: [contractorId], references: [id])
  approvals          PermitApproval[]

  @@map("permit")
}

model PermitApproval {
  id         String           @id @default(uuid())
  permitId   String           @map("permit_id")
  department ApprovalDepartment
  status     ApprovalStatus   @default(pending)
  deadline   DateTime
  comment    String?
  decidedAt  DateTime?        @map("decided_at")
  createdAt  DateTime         @default(now()) @map("created_at")

  permit     Permit           @relation(fields: [permitId], references: [id], onDelete: Cascade)

  @@map("permit_approval")
}

// ─── Violations (Акты нарушений) ────────────────────────────────

enum ViolationSeverity {
  low
  medium
  high
  critical
}

enum ViolationStatus {
  pending
  resolved
  escalated
}

model Violation {
  id                String           @id @default(uuid())
  contractorId      String           @map("contractor_id")
  date              DateTime
  description       String
  severity          ViolationSeverity
  status            ViolationStatus  @default(pending)
  department        String
  createdById       String           @map("created_by_id")
  photoUrl          String?          @map("photo_url")
  resolvedAt        DateTime?        @map("resolved_at")
  resolutionNotes   String?          @map("resolution_notes")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  contractor        Organization     @relation(fields: [contractorId], references: [id])
  createdBy         User             @relation("ViolationCreator", fields: [createdById], references: [id])

  @@map("violation")
}

model ViolationTemplate {
  id                String           @id @default(uuid())
  title             String
  description       String
  defaultSeverity   ViolationSeverity @default(medium) @map("default_severity")
  department        String
  isActive          Boolean          @default(true) @map("is_active")
  createdById       String           @map("created_by_id")
  createdAt         DateTime         @default(now()) @map("created_at")

  createdBy         User             @relation("TemplateCreator", fields: [createdById], references: [id])

  @@map("violation_template")
}

// ─── Checklists (Чек-листы) ──────────────────────────────────────

enum ChecklistStatus {
  in_progress
  passed
  failed
}

model Checklist {
  id              String           @id @default(uuid())
  contractorId    String           @map("contractor_id")
  inspectorName   String           @map("inspector_name")
  date            DateTime
  score           Int?
  status          ChecklistStatus  @default(in_progress)
  comments        String?
  createdById     String           @map("created_by_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  contractor      Organization     @relation(fields: [contractorId], references: [id])
  createdBy       User             @relation("ChecklistCreator", fields: [createdById], references: [id])
  items           ChecklistItem[]

  @@map("checklist")
}

model ChecklistItem {
  id            String         @id @default(uuid())
  checklistId   String         @map("checklist_id")
  question      String
  answer        String         // pass, fail, n/a
  comment       String?
  photoUrl      String?        @map("photo_url")

  checklist     Checklist      @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@map("checklist_item")
}

// ─── Regulatory Documents (Нормативные документы) ───────────────

enum FileType {
  pdf
  docx
  xlsx
}

model RegDocumentSection {
  id        String           @id @default(uuid())
  name      String
  parentId  String?          @map("parent_id")
  order     Int              @default(0)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  parent    RegDocumentSection? @relation("SectionParent", fields: [parentId], references: [id])
  children  RegDocumentSection[] @relation("SectionParent")
  documents RegDocument[]

  @@map("reg_document_section")
}

model RegDocument {
  id        String    @id @default(uuid())
  title     String
  sectionId String    @map("section_id")
  fileUrl   String    @map("file_url")
  fileType  FileType
  version   Int       @default(1)
  createdById String  @map("created_by_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  section   RegDocumentSection @relation(fields: [sectionId], references: [id])
  createdBy User               @relation("RegDocCreator", fields: [createdById], references: [id])

  @@map("reg_document")
}

model NotificationSubscription {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  emailOnUpdate Boolean  @default(true) @map("email_on_update")
  createdAt     DateTime @default(now()) @map("created_at")

  user          User     @relation("NotificationSubscriber", fields: [userId], references: [id])

  @@unique([userId])
  @@map("notification_subscription")
}
